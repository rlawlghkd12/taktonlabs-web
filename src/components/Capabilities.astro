---
import CapabilityCard from './CapabilityCard.astro';
import { capabilities } from '../data/capabilities';
---
<section id="capabilities" class="cap">
  <div class="cap-pin">
    <div class="cap-head">
      <div class="cap-eyebrow" data-cap-eyebrow>
        <span class="cap-eyebrow-static">CAPABILITIES &nbsp;/&nbsp;</span>
        <span class="cap-title-stack" data-cap-title-stack>
          <span class="cap-title-item" data-title-idx="0">01 · 웹 · 모바일 제품</span>
          <span class="cap-title-item" data-title-idx="1">02 · 데스크톱 앱</span>
          <span class="cap-title-item" data-title-idx="2">03 · B2B 맞춤 개발</span>
        </span>
      </div>
      <div class="cap-progress" data-cap-progress>
        <div class="cap-progress-seg" data-seg="0"></div>
        <div class="cap-progress-seg" data-seg="1"></div>
        <div class="cap-progress-seg" data-seg="2"></div>
      </div>
    </div>

    <h2 class="cap-headline" data-cap-headline>
      세 가지로 만듭니다.
    </h2>

    <!-- dock bar: 3 docked slots (초기엔 hidden, 카드가 이동하며 채움) -->
    <div class="cap-dock-bar">
      {capabilities.map((c, i) => (
        <div class="cap-dock" data-cap-dock data-index={i}>
          <span class="dock-num">{c.index}</span>
          <span class="dock-title">{c.title}</span>
          <span class="dock-check">✓</span>
        </div>
      ))}
    </div>

    <!-- BIG 카드 stage: 3 카드가 absolute 겹쳐있음 -->
    <div class="cap-stage" data-cap-stage>
      {capabilities.map((c, i) => (
        <CapabilityCard capability={c} index={i} />
      ))}
      <div class="cap-outro" data-cap-outro>
        <p class="cap-outro-title">따로 맡겨도,<br />세 영역을 함께 설계해도.</p>
        <a href="#process" class="cap-outro-link">진행 방식 보기 ↓</a>
      </div>
    </div>
  </div>
</section>
<style>
  .cap { position: relative; background: var(--bg-primary); color: var(--text-primary); padding-top: 120px; }
  .cap-pin { padding: 40px var(--section-pad-x); min-height: 100vh; display: flex; flex-direction: column; }
  .cap-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
  .cap-eyebrow { font-family: var(--font-mono); font-size: 14px; letter-spacing: var(--tracking-eyebrow); color: var(--text-muted); display: inline-flex; align-items: baseline; gap: 4px; }
  .cap-eyebrow-static { flex-shrink: 0; }
  .cap-title-stack { position: relative; display: inline-block; min-width: 260px; height: 1.3em; }
  .cap-title-item { position: absolute; left: 0; top: 0; white-space: nowrap; color: var(--text-primary); opacity: 0; transition: opacity 0.35s var(--ease-smooth); }
  .cap-title-item[data-title-idx="0"] { opacity: 1; }
  .cap-progress { display: flex; gap: 3px; width: 120px; }
  .cap-progress-seg { flex: 1; height: 2px; background: var(--hairline); position: relative; overflow: hidden; }
  .cap-progress-seg::after { content: ''; position: absolute; inset: 0; background: var(--text-primary); transform: scaleX(0); transform-origin: left; transition: transform 0.3s var(--ease-expo); }
  .cap-progress-seg[data-filled='true']::after { transform: scaleX(1); }
  .cap-headline { font-size: clamp(40px, 6vw, 64px); font-weight: 600; letter-spacing: -0.04em; margin: 0 0 48px; line-height: 1; }
  .cap-dock-bar { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; margin-bottom: 56px; min-height: 92px; }
  .cap-dock {
    display: flex; flex-direction: column; align-items: flex-start; gap: 8px;
    padding: 18px 22px;
    background: #fff; border: 1px solid var(--hairline); border-radius: 12px;
    box-shadow: 0 2px 8px -4px rgba(0,0,0,0.05);
    opacity: 0;                  /* 초기 hidden, 타임라인에서 띄움 */
    transition: opacity 0.3s var(--ease-smooth);
    position: relative;
    overflow: hidden;
  }
  .cap-dock::before {
    content: '';
    position: absolute; left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--text-primary);
    opacity: 0.85;
  }
  .dock-num {
    font-family: var(--font-mono);
    font-size: 20px;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .dock-title {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }
  .dock-check {
    position: absolute;
    top: 18px; right: 22px;
    font-size: 14px; color: var(--text-muted); opacity: 0.6;
  }
  .cap-stage { position: relative; flex: 1; min-height: 340px; }
  .cap-outro {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 32px;
    opacity: 0;
    pointer-events: none;
  }
  .cap-outro-title {
    font-size: clamp(32px, 4.5vw, 52px);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0;
    max-width: 900px;
  }
  .cap-outro-link {
    font-size: 16px;
    color: var(--text-primary);
    border-bottom: 1px solid var(--text-primary);
    padding-bottom: 2px;
    text-decoration: none;
    font-weight: 500;
    transition: opacity 0.2s var(--ease-smooth);
  }
  .cap-outro-link:hover { opacity: 0.7; }

  @media (max-width: 768px) {
    .cap-pin { padding: 48px var(--section-pad-x-sm); min-height: auto; }
    .cap-headline { font-size: 32px; margin-bottom: 32px; }
    .cap-dock-bar { display: none; }
    .cap-stage { min-height: auto; display: flex; flex-direction: column; gap: 16px; }
  }
</style>

<script>
  import { initCapabilitiesMorph } from '../scripts/sections/capabilities-morph';
  initCapabilitiesMorph();
</script>
