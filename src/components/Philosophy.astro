---
const principles = [
  { tag: '01 · ONE TEAM', line1: '설계·개발·운영을', line2: '한 팀이 전담합니다.' },
  { tag: '02 · IN THE FIELD', line1: '쓰이는 장면을', line2: '직접 보고 고칩니다.' },
  { tag: '03 · NO FRICTION LEFT', line1: '작은 마찰까지 오래', line2: '남겨두지 않습니다.' },
];
---
<section id="philosophy" class="phil">
  <div class="phil-inner">
    <div class="phil-eyebrow">02 &nbsp;&nbsp; PHILOSOPHY</div>
    <h2 class="phil-headline">
      <span>쓰이는 소프트웨어가</span>
      <span class="highlight">
        <svg
          class="highlight-brush"
          data-phil-brush
          viewBox="0 0 640 170"
          preserveAspectRatio="none"
          aria-hidden="true"
          focusable="false"
          xmlns="http://www.w3.org/2000/svg"
        >
          <defs>
            <!-- 거칠기 필터: 저주파(x) + 고주파(y)로 가로로 긴 붓결 결 구현 -->
            <filter id="phil-brush-rough" x="-8%" y="-30%" width="116%" height="160%" filterUnits="userSpaceOnUse">
              <feTurbulence type="fractalNoise" baseFrequency="0.012 0.09" numOctaves="3" seed="11" />
              <feDisplacementMap in="SourceGraphic" scale="26" />
            </filter>
            <!-- 끝단 페더 효과용 soft blur -->
            <filter id="phil-brush-soft" x="-10%" y="-20%" width="120%" height="140%" filterUnits="userSpaceOnUse">
              <feGaussianBlur stdDeviation="0.6" />
            </filter>
          </defs>

          <!-- 메인 몸체 (거칠기 필터 적용) -->
          <g filter="url(#phil-brush-rough)" fill="currentColor">
            <!-- 본체: 좌측 약간 두껍고 우측으로 흐르는 S-curve -->
            <path d="
              M 70 72
              C 130 58, 230 62, 330 64
              C 420 66, 510 72, 575 80
              C 598 84, 600 92, 578 100
              C 490 112, 360 104, 250 102
              C 160 100, 100 98, 70 92
              C 50 86, 55 78, 70 72 Z
            " />

            <!-- 좌측 붓자국 기점 (얇은 삼각 꼬리) -->
            <path d="M 70 70 L 32 54 L 46 64 L 22 62 Z" />
            <path d="M 62 82 L 20 80 L 38 88 L 16 90 Z" />
            <path d="M 68 94 L 24 100 L 40 104 L 20 110 Z" />

            <!-- 우측 붓자국 끝단 (가장 풍부한 바리스트) -->
            <path d="M 590 70 L 628 58 L 612 66 L 632 68 L 614 72 Z" />
            <path d="M 594 82 L 634 82 L 618 87 L 636 90 L 616 92 Z" />
            <path d="M 586 93 L 628 100 L 612 104 L 630 108 L 612 112 Z" />
            <path d="M 576 102 L 614 114 L 600 118 L 622 122 L 602 126 Z" />
            <path d="M 564 110 L 598 126 L 582 130 L 606 138 Z" />

            <!-- 상단 wisp (짧게 위로 튀는 붓털) -->
            <path d="M 170 62 L 162 30 L 170 40 Z" />
            <path d="M 260 58 L 268 24 L 272 34 Z" />
            <path d="M 360 58 L 362 28 L 368 36 Z" />
            <path d="M 460 62 L 466 34 L 472 42 Z" />

            <!-- 하단 wisp (붓자국 아래로 흐르는 방울) -->
            <path d="M 140 104 L 134 138 L 140 128 Z" />
            <path d="M 230 106 L 232 144 L 228 132 Z" />
            <path d="M 340 106 L 344 140 L 348 128 Z" />
            <path d="M 450 102 L 456 136 L 462 126 Z" />

            <!-- 스플래터 (먼 곳에 튄 잉크) -->
            <circle cx="26" cy="44" r="2" />
            <circle cx="48" cy="34" r="1.4" />
            <circle cx="602" cy="46" r="2.4" />
            <circle cx="632" cy="108" r="2" />
            <circle cx="574" cy="148" r="2.6" />
            <circle cx="42" cy="130" r="1.8" />
          </g>

          <!-- 내부 붓결 (soft-light 블렌드로 종이 결 느낌) -->
          <g filter="url(#phil-brush-rough)" fill="none" stroke="rgba(0,0,0,0.22)" stroke-linecap="round" stroke-width="1.1">
            <path d="M 90 78 C 220 74, 360 80, 560 88" />
            <path d="M 80 88 C 220 88, 360 90, 558 94" />
            <path d="M 100 96 C 240 96, 380 96, 548 100" />
            <path d="M 110 84 C 250 82, 400 86, 540 92" />
          </g>

          <!-- 외곽 부드러운 테두리 (살짝 blur) — 종이에 스민 효과 -->
          <g filter="url(#phil-brush-soft)" fill="currentColor" opacity="0.35">
            <path d="
              M 75 74 C 135 62, 230 64, 330 66
              C 420 68, 510 74, 572 82
              C 592 86, 594 92, 574 98
              C 490 108, 360 102, 250 100
              C 160 98, 100 96, 72 90
              C 54 86, 58 80, 75 74 Z
            " />
          </g>
        </svg>
        <span class="highlight-text">오래 쓰이는</span>
      </span>
      <span>소프트웨어입니다.</span>
    </h2>
    <div class="phil-grid">
      {principles.map((p) => (
        <div class="phil-principle" data-phil-principle>
          <div class="phil-principle-tag">{p.tag}</div>
          <div class="phil-principle-line">{p.line1}<br />{p.line2}</div>
        </div>
      ))}
    </div>
  </div>
</section>
<style>
  .phil { padding: var(--section-pad-y) var(--section-pad-x); background: var(--bg-primary); color: var(--text-primary); }
  .phil-inner { max-width: var(--container-wide); margin: 0 auto; }
  .phil-eyebrow {
    font-family: var(--font-mono); font-size: 14px;
    letter-spacing: var(--tracking-eyebrow); color: var(--text-muted);
    margin-bottom: 32px;
  }
  .phil-headline {
    font-size: clamp(44px, 7vw, 80px); font-weight: 600;
    letter-spacing: var(--tracking-headline); line-height: 1.02;
    max-width: 1100px; margin: 0 0 72px;
  }
  .phil-headline .highlight {
    position: relative;
    display: inline-block;
    padding: 0 16px;
  }
  .phil-headline .highlight-brush {
    position: absolute;
    left: -16px;
    right: -16px;
    bottom: -0.26em;
    width: calc(100% + 32px);
    height: 1.34em;
    pointer-events: none;
    overflow: visible;
    color: var(--accent-highlight);
    z-index: 0;
    /* 초기 상태 — 좌→우 붓칠 애니메이션 대기 */
    clip-path: inset(0 100% 0 0);
    -webkit-clip-path: inset(0 100% 0 0);
    will-change: clip-path;
  }
  .phil-headline .highlight-text {
    position: relative;
    z-index: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .phil-headline .highlight-brush {
      clip-path: none;
      -webkit-clip-path: none;
    }
  }
  .phil-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; padding-top: 28px; border-top: 1px solid var(--hairline-strong); }
  .phil-principle-tag {
    font-family: var(--font-mono); font-size: 14px;
    letter-spacing: var(--tracking-mono-label); color: var(--text-muted);
    margin-bottom: 10px;
  }
  .phil-principle-line { font-size: 16px; line-height: 1.65; color: var(--text-primary); }
  @media (max-width: 768px) {
    .phil { padding: 72px var(--section-pad-x-sm); }
    .phil-headline { font-size: 38px; margin-bottom: 48px; }
    .phil-grid { grid-template-columns: 1fr; gap: 24px; }
  }
</style>

<script>
  // 붓칠 스크럽 애니메이션 — 스크롤하면 좌→우로 clip-path 확장
  import { prefersReducedMotion, loadGsap } from '../lib/motion';

  async function initPhilBrush(): Promise<void> {
    const brush = document.querySelector<SVGElement>('[data-phil-brush]');
    if (!brush) return;

    if (prefersReducedMotion()) {
      brush.style.clipPath = 'none';
      (brush.style as CSSStyleDeclaration & { webkitClipPath?: string }).webkitClipPath = 'none';
      return;
    }

    const { gsap } = await loadGsap();

    gsap.fromTo(
      brush,
      { clipPath: 'inset(0 100% 0 0)', webkitClipPath: 'inset(0 100% 0 0)' },
      {
        clipPath: 'inset(0 0% 0 0)',
        webkitClipPath: 'inset(0 0% 0 0)',
        ease: 'none',
        scrollTrigger: {
          trigger: '#philosophy .phil-headline',
          start: 'top 80%',
          end: 'top 35%',
          scrub: 0.8,
        },
      },
    );
  }

  initPhilBrush();
</script>
