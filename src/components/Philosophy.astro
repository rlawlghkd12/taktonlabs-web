---
const principles = [
  { tag: '01 · ONE TEAM', line1: '설계·개발·운영을', line2: '한 팀이 전담합니다.' },
  { tag: '02 · IN THE FIELD', line1: '쓰이는 장면을', line2: '직접 보고 고칩니다.' },
  { tag: '03 · NO FRICTION LEFT', line1: '작은 마찰까지 오래', line2: '남겨두지 않습니다.' },
];
---
<section id="philosophy" class="phil">
  <div class="phil-inner">
    <div class="phil-eyebrow">02 &nbsp;&nbsp; PHILOSOPHY</div>
    <h2 class="phil-headline">
      <span>쓰이는 소프트웨어가</span>
      <span class="highlight">
        <svg
          class="highlight-brush"
          data-phil-brush
          viewBox="0 0 640 150"
          preserveAspectRatio="none"
          aria-hidden="true"
          focusable="false"
          xmlns="http://www.w3.org/2000/svg"
        >
          <defs>
            <!-- 거칠기 필터: 가로결 강조 -->
            <filter id="phil-brush-rough" x="-5%" y="-25%" width="110%" height="150%" filterUnits="userSpaceOnUse">
              <feTurbulence type="fractalNoise" baseFrequency="0.014 0.12" numOctaves="2" seed="6" />
              <feDisplacementMap in="SourceGraphic" scale="14" />
            </filter>
            <!-- 바리스트 전용: 세로 결 강조해 털 질감 -->
            <filter id="phil-brush-bristle" x="-5%" y="-30%" width="110%" height="160%" filterUnits="userSpaceOnUse">
              <feTurbulence type="fractalNoise" baseFrequency="0.02 0.18" numOctaves="2" seed="13" />
              <feDisplacementMap in="SourceGraphic" scale="9" />
            </filter>
          </defs>

          <!-- ① 좌측 무거운 둥근 시작점 (brush landing) — 살짝 아래에서 시작 -->
          <g filter="url(#phil-brush-rough)" fill="currentColor">
            <path d="
              M 40 88
              C 26 84, 22 76, 28 68
              C 34 60, 48 58, 62 62
              C 74 65, 82 70, 86 76
              L 86 92
              C 80 98, 66 102, 52 100
              C 42 98, 38 94, 40 88 Z
            " />
          </g>

          <!-- ② 본체 (좌하 → 우상 살짝 sweep, 오른쪽으로 갈수록 얇아짐) -->
          <g filter="url(#phil-brush-rough)" fill="currentColor">
            <path d="
              M 82 70
              C 180 64, 300 60, 420 60
              C 470 60, 510 62, 540 66
              L 544 78
              C 510 82, 430 84, 320 84
              C 200 84, 130 86, 86 90
              C 82 84, 80 76, 82 70 Z
            " />
          </g>

          <!-- ③ 본체 내부 "붓털 사이 틈" — 배경색 얇은 가로줄, 직접 stroke gap 효과 -->
          <g filter="url(#phil-brush-rough)" fill="none" stroke="#fafaf7" stroke-linecap="round" opacity="0.7">
            <path d="M 110 66 C 240 62, 360 62, 510 66" stroke-width="0.7" />
            <path d="M 120 74 C 260 72, 380 74, 520 76" stroke-width="0.55" />
            <path d="M 100 82 C 240 82, 380 82, 510 82" stroke-width="0.9" />
          </g>

          <!-- ④ 우측 바리스트 — 두꺼운 내부 층 (본체에서 뻗는 굵은 털) -->
          <g filter="url(#phil-brush-bristle)" stroke="currentColor" stroke-linecap="round" fill="none">
            <path d="M 540 66 C 568 62, 590 58, 612 54" stroke-width="2.2" />
            <path d="M 542 70 C 572 66, 600 64, 624 62" stroke-width="2.1" />
            <path d="M 544 74 C 576 72, 608 70, 630 68" stroke-width="2" />
            <path d="M 546 78 C 580 77, 612 76, 632 74" stroke-width="1.9" />
            <path d="M 544 82 C 578 82, 610 82, 630 82" stroke-width="1.8" />
            <path d="M 542 86 C 572 88, 602 90, 624 91" stroke-width="1.7" />
            <path d="M 538 90 C 566 94, 594 98, 614 100" stroke-width="1.5" />
          </g>

          <!-- ⑤ 우측 바리스트 — 얇은 외곽 층 (가장 멀리 뻗는 wispy hair) -->
          <g filter="url(#phil-brush-bristle)" stroke="currentColor" stroke-linecap="round" fill="none" opacity="0.82">
            <path d="M 556 56 C 588 48, 612 44, 634 42" stroke-width="0.9" />
            <path d="M 562 62 C 596 56, 622 54, 636 52" stroke-width="0.85" />
            <path d="M 560 78 C 596 77, 624 76, 638 76" stroke-width="0.8" />
            <path d="M 556 90 C 588 94, 616 98, 636 102" stroke-width="0.85" />
            <path d="M 548 98 C 576 106, 600 112, 620 116" stroke-width="0.9" />
          </g>

          <!-- ⑥ 좌측 바리스트 — 최소한만 (시작 지점 뻗는 짧은 2개) -->
          <g filter="url(#phil-brush-bristle)" stroke="currentColor" stroke-linecap="round" fill="none" opacity="0.85">
            <path d="M 28 72 L 8 68" stroke-width="1.3" />
            <path d="M 32 92 L 10 98" stroke-width="1.2" />
          </g>

          <!-- ⑦ 스플래터 — 양끝 근처 최소 배치 -->
          <g fill="currentColor">
            <circle cx="14" cy="62" r="1.3" />
            <circle cx="20" cy="108" r="1.4" />
            <circle cx="632" cy="38" r="1.5" />
            <circle cx="628" cy="118" r="1.3" />
            <circle cx="608" cy="48" r="0.9" />
          </g>
        </svg>
        <span class="highlight-text">오래 쓰이는</span>
      </span>
      <span>소프트웨어입니다.</span>
    </h2>
    <div class="phil-grid">
      {principles.map((p) => (
        <div class="phil-principle" data-phil-principle>
          <div class="phil-principle-tag">{p.tag}</div>
          <div class="phil-principle-line">{p.line1}<br />{p.line2}</div>
        </div>
      ))}
    </div>
  </div>
</section>
<style>
  .phil { padding: var(--section-pad-y) var(--section-pad-x); background: var(--bg-primary); color: var(--text-primary); }
  .phil-inner { max-width: var(--container-wide); margin: 0 auto; }
  .phil-eyebrow {
    font-family: var(--font-mono); font-size: 14px;
    letter-spacing: var(--tracking-eyebrow); color: var(--text-muted);
    margin-bottom: 32px;
  }
  .phil-headline {
    font-size: clamp(44px, 7vw, 80px); font-weight: 600;
    letter-spacing: var(--tracking-headline); line-height: 1.02;
    max-width: 1100px; margin: 0 0 72px;
  }
  .phil-headline .highlight {
    position: relative;
    display: inline-block;
    padding: 0 16px;
  }
  .phil-headline .highlight-brush {
    position: absolute;
    left: -16px;
    right: -16px;
    bottom: -0.26em;
    width: calc(100% + 32px);
    height: 1.34em;
    pointer-events: none;
    overflow: visible;
    color: var(--accent-highlight);
    z-index: 0;
    /* 초기 상태 — 좌→우 붓칠 애니메이션 대기 */
    clip-path: inset(0 100% 0 0);
    -webkit-clip-path: inset(0 100% 0 0);
    will-change: clip-path;
  }
  .phil-headline .highlight-text {
    position: relative;
    z-index: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .phil-headline .highlight-brush {
      clip-path: none;
      -webkit-clip-path: none;
    }
  }
  .phil-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; padding-top: 28px; border-top: 1px solid var(--hairline-strong); }
  .phil-principle-tag {
    font-family: var(--font-mono); font-size: 14px;
    letter-spacing: var(--tracking-mono-label); color: var(--text-muted);
    margin-bottom: 10px;
  }
  .phil-principle-line { font-size: 16px; line-height: 1.65; color: var(--text-primary); }
  @media (max-width: 768px) {
    .phil { padding: 72px var(--section-pad-x-sm); }
    .phil-headline { font-size: 38px; margin-bottom: 48px; }
    .phil-grid { grid-template-columns: 1fr; gap: 24px; }
  }
</style>

<script>
  // 붓칠 스크럽 애니메이션 — 스크롤하면 좌→우로 clip-path 확장
  import { prefersReducedMotion, loadGsap } from '../lib/motion';

  async function initPhilBrush(): Promise<void> {
    const brush = document.querySelector<SVGElement>('[data-phil-brush]');
    if (!brush) return;

    if (prefersReducedMotion()) {
      brush.style.clipPath = 'none';
      (brush.style as CSSStyleDeclaration & { webkitClipPath?: string }).webkitClipPath = 'none';
      return;
    }

    const { gsap } = await loadGsap();

    gsap.fromTo(
      brush,
      { clipPath: 'inset(0 100% 0 0)', webkitClipPath: 'inset(0 100% 0 0)' },
      {
        clipPath: 'inset(0 0% 0 0)',
        webkitClipPath: 'inset(0 0% 0 0)',
        duration: 1.2,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '#philosophy .phil-headline',
          start: 'top 75%',
          toggleActions: 'play none none reverse',
        },
      },
    );
  }

  initPhilBrush();
</script>
