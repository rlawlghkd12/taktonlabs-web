---
import Base from '../../layouts/Base.astro';
import Footer from '../../components/Footer.astro';
import TutomateDownloadPage from '../../components/TutomateDownloadPage.astro';
import { tutomateQ } from '../../data/tutomate';

const pageTitle = `${tutomateQ.name} — ${tutomateQ.tagline} | Taktonlabs`;
const pageDescription = tutomateQ.description;
---

<Base
  title={pageTitle}
  description={pageDescription}
  breadcrumbs={[
    { name: '홈', url: '/' },
    { name: 'TutorMate Q', url: '/tutomate/q' },
  ]}
>
  <TutomateDownloadPage variant={tutomateQ} />
  <Footer />
</Base>
